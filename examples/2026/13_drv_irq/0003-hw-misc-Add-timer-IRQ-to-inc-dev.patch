From e3b6b059e84dfc23c7bd6e9636acf419b7fbe406 Mon Sep 17 00:00:00 2001
From: Viktor Prutyanov <viktor.prutyanov@phystech.edu>
Date: Tue, 24 Feb 2026 00:56:08 +0300
Subject: [PATCH 3/3] hw/misc: Add timer IRQ to inc-dev

Signed-off-by: Viktor Prutyanov <viktor.prutyanov@phystech.edu>
---
 hw/arm/virt.c             |  8 +++++++-
 hw/misc/inc-dev.c         | 13 +++++++++++++
 include/hw/misc/inc-dev.h |  5 +++++
 3 files changed, 25 insertions(+), 1 deletion(-)

diff --git a/hw/arm/virt.c b/hw/arm/virt.c
index 5f080cd..d329a4c 100644
--- a/hw/arm/virt.c
+++ b/hw/arm/virt.c
@@ -225,6 +225,7 @@ static const int a15irqmap[] = {
     [VIRT_GPIO] = 7,
     [VIRT_UART1] = 8,
     [VIRT_ACPI_GED] = 9,
+    [VIRT_INC_DEV] = 10,
     [VIRT_MMIO] = 16, /* ...to 16 + NUM_VIRTIO_TRANSPORTS - 1 */
     [VIRT_GIC_V2M] = 48, /* ...to 48 + NUM_GICV2M_SPIS - 1 */
     [VIRT_SMMU] = 74,    /* ...to 74 + NUM_SMMU_IRQS - 1 */
@@ -2098,8 +2099,9 @@ static void virt_cpu_post_init(VirtMachineState *vms, MemoryRegion *sysmem)
 static void create_inc_dev(VirtMachineState *vms)
 {
     hwaddr base = vms->memmap[VIRT_INC_DEV].base;
+    int irq = vms->irqmap[VIRT_INC_DEV];
 
-    sysbus_create_simple("inc-dev", base, NULL);
+    sysbus_create_simple("inc-dev", base, qdev_get_gpio_in(vms->gic, irq));
 
     MachineState *ms = MACHINE(vms);
     char *name = g_strdup_printf("/mmio-dev@%lx", (long)vms->memmap[VIRT_INC_DEV].base);
@@ -2108,6 +2110,10 @@ static void create_inc_dev(VirtMachineState *vms)
     qemu_fdt_setprop_cells(ms->fdt, name, "reg",
             0x0, vms->memmap[VIRT_INC_DEV].base,
             0x0, vms->memmap[VIRT_INC_DEV].size);
+    qemu_fdt_setprop_cell(ms->fdt, name, "interrupt-parent", vms->gic_phandle);
+    qemu_fdt_setprop_cell(ms->fdt, name, "interrupts", irq);
+    qemu_fdt_setprop_cells(ms->fdt, name, "interrupts",
+            GIC_FDT_IRQ_TYPE_SPI, irq, GIC_FDT_IRQ_FLAGS_EDGE_LO_HI);
     g_free(name);
 }
 
diff --git a/hw/misc/inc-dev.c b/hw/misc/inc-dev.c
index 4138653..4bcd45f 100644
--- a/hw/misc/inc-dev.c
+++ b/hw/misc/inc-dev.c
@@ -30,6 +30,15 @@ static const MemoryRegionOps inc_dev_ops = {
     .endianness = DEVICE_LITTLE_ENDIAN,
 };
 
+static void inc_dev_timeout_cb(void *opaque)
+{
+    IncDev *s = opaque;
+
+    qemu_irq_pulse(s->irq);
+
+    timer_mod(s->timer, qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL) + 1000);
+}
+
 static void inc_dev_init(Object *obj)
 {
     IncDev *s = INC_DEV(obj);
@@ -42,6 +51,10 @@ static void inc_dev_init(Object *obj)
     memory_region_init_io(&s->iomem, OBJECT(s), &inc_dev_ops, s,
                           TYPE_INC_DEV, INC_DEV_SIZE);
     sysbus_init_mmio(sbd, &s->iomem);
+    sysbus_init_irq(sbd, &s->irq);
+
+    s->timer = timer_new_ms(QEMU_CLOCK_VIRTUAL, inc_dev_timeout_cb, s);
+    timer_mod(s->timer, qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL) + 1000);
 }
 
 static void inc_dev_class_init(ObjectClass *klass, void *data)
diff --git a/include/hw/misc/inc-dev.h b/include/hw/misc/inc-dev.h
index 8818c4b..315a503 100644
--- a/include/hw/misc/inc-dev.h
+++ b/include/hw/misc/inc-dev.h
@@ -1,6 +1,9 @@
 #include "hw/sysbus.h"
 #include "exec/memory.h"
+#include "qemu/typedefs.h"
 #include "qom/object.h"
+#include "qemu/timer.h"
+#include "hw/irq.h"
 
 #define INC_DEV_SIZE 0x1000
 
@@ -8,6 +11,8 @@ struct IncDev {
     SysBusDevice parent_obj;
     MemoryRegion iomem;
     uint64_t cnt;
+    qemu_irq irq;
+    QEMUTimer *timer;
 };
 
 #define TYPE_INC_DEV "inc-dev"
-- 
2.47.1

